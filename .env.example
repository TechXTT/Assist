# --- Database ---
# SQLite for local dev. Swap for a Postgres URL when deploying (Neon free tier).
DATABASE_URL="file:./dev.db"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# Generate in PowerShell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Max 256 }))
NEXTAUTH_SECRET=""

# --- Google OAuth ---
# Create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# Enable scopes: Calendar (readonly) + Gmail (readonly) on the consent screen.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Single-user gate ---
# Only this Google email is allowed to sign in.
ALLOWED_EMAIL="marogo142005@gmail.com"

# --- Optional AI (Anthropic) ---
# Leave blank to fall back to template strings.
ANTHROPIC_API_KEY=""
AI_MONTHLY_CAP_USD="5"

# --- UX defaults ---
DEFAULT_TIMEZONE="Europe/Amsterdam"
DEFAULT_CURRENCY="EUR"

# --- Calendar sync ---
# Auto-sync events when last sync is older than this many minutes (dashboard load only).
CALENDAR_SYNC_STALENESS_MINUTES="15"

# --- Cron (v2 — Inbox & Outbox) ---
# Shared secret guarding /api/cron/* route handlers. Vercel will inject this as
# Authorization: Bearer <CRON_SECRET> on scheduled fires when set in project env.
# Generate with:  openssl rand -base64 32
CRON_SECRET=""

# --- Market data (v3 — Smart Money) ---
# Twelve Data free tier: https://twelvedata.com/pricing — sign up, copy key.
# Used by the daily /api/cron/prices job to refresh Holding.lastKnownPriceCents.
# Leave blank to disable live prices (holdings stay manual).
TWELVE_DATA_API_KEY=""

# --- Banking (v4 — Enable Banking) ---
# Sign up at https://enablebanking.com → Control Panel → Applications → "+".
# Free for personal use. Supports Revolut + ~2500 EU/UK/Nordic banks via PSD2.
#
# After creating an application:
#   1. Download or copy the RSA private key (PEM format, multi-line).
#   2. Base64-encode it for safe storage in this file:
#        base64 -w 0 < private.pem    # Linux
#        base64 -i private.pem        # macOS
#      Paste the resulting one-line string below.
# Both vars required to enable the bank connection flow in /settings.
ENABLE_BANKING_APPLICATION_ID=""
ENABLE_BANKING_PRIVATE_KEY_BASE64=""
